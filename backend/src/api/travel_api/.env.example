# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=travel_buddy
DB_USER=postgres
DB_PASS=yourpassword

# ── OpenTripMap ───────────────────────────────────────────────
# Đăng ký miễn phí: https://dev.opentripmap.org/product
# Free tier: 500 request/ngày
OPENTRIPMAP_KEY=your_key_here

# ── Amadeus ───────────────────────────────────────────────────
# Đăng ký miễn phí: https://developers.amadeus.com
# Sandbox: unlimited test requests, data gần thực tế
AMADEUS_API_KEY=your_key_here
AMADEUS_API_SECRET=your_secret_here
AMADEUS_ENV=test   # test | production

# ── Open-Meteo, RestCountries, Frankfurter ────────────────────
# Không cần key — gọi trực tiếp
