# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=travel_buddy
DB_USER=postgres
DB_PASS=travelbuddy_postgres_pass
TRAVELBUDDY_DATA_MODE=auto

# OpenTripMap POI enrichment
# Register: https://dev.opentripmap.org/product
OPENTRIPMAP_KEY=
OPENTRIPMAP_LANG=vi

# Flight prices
# Use serpapi for MVP when Amadeus signup is blocked.
FLIGHT_PRICE_PROVIDER=serpapi
SERPAPI_API_KEY=
SERPAPI_GOOGLE_DOMAIN=google.com
SERPAPI_GL=vn
SERPAPI_HL=vi
HOTEL_PRICE_PROVIDER=serpapi
HOTEL_SEARCH_ADULTS=2

# Amadeus fallback/provider switch
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# Booking.com Demand API hotel rates
# Requires partner approval/token.
BOOKING_ENV=sandbox
BOOKING_API_TOKEN=
BOOKING_AFFILIATE_ID=

# RestCountries v5 is optional; collector falls back to manual metadata when empty.
RESTCOUNTRIES_API_KEY=

# Open-Meteo and Frankfurter do not need keys.
