DB_HOST=localhost
DB_PORT=5432
DB_NAME=travel_buddy
DB_USER=postgres
DB_PASS=yourpassword
TRAVELBUDDY_DATA_MODE=auto

# Amadeus API (đăng ký miễn phí tại developers.amadeus.com)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# OpenTripMap (POI)
OPENTRIPMAP_KEY=
OPENTRIPMAP_LANG=vi

# Booking.com Demand API (hotel rates, optional)
BOOKING_ENV=sandbox
BOOKING_API_TOKEN=
BOOKING_AFFILIATE_ID=

# RestCountries v5 (optional; fallback seed nếu trống)
RESTCOUNTRIES_API_KEY=
