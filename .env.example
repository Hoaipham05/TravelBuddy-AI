# ── LLM Provider ─────────────────────────────────────────────────────────────
# Chọn 1 trong: openai | vllm | groq | gemini
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.3

# Groq (optional)
GROQ_API_KEY=xxxxxxxxxxxxx
GROQ_MODEL=qwen/qwen3-32b
GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct,llama-3.2-90b-vision-preview,llama-3.2-11b-vision-preview
# Alternatives: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it

## vLLM (LLM_PROVIDER=vllm) – OpenAI-compatible self-hosted
VLLM_BASE_URL=xxxxxxxxxxxxxxxxxxxxxxxx
VLLM_MODEL=Qwen/Qwen3.5-4B
VLLM_API_KEY=EMPTY
#
## OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
#
## Gemini (LLM_PROVIDER=gemini)
#GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Search ────────────────────────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8888
WEB_SEARCH_TOP_K=5
SEARCH_MODE_DEFAULT=hybrid   # hybrid | on | off
SERPER_API_KEY=xxxxxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600        # 1 giờ
REDIS_RESULT_TTL=300          # 5 phút
REDIS_CACHE_TTL=300           # 5 phút (search cache)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=20             # max requests/phút/user

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── SearXNG (docker-compose) ──────────────────────────────────────────────────
SEARXNG_SECRET_KEY=change_me
REDIS_PASSWORD=change_me
